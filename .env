import { useState } from 'react';
import { base44 } from '@/api/base44Client';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogTrigger } from '@/components/ui/dialog';
import { Plus, Pencil, Trash2, Loader2, GraduationCap, Users, ClipboardCheck, Mail } from 'lucide-react';
import { Link } from 'react-router-dom';

const tabs = [
  { id: 'alunos', label: 'Alunos', icon: Users },
  { id: 'disciplinas', label: 'Disciplinas', icon: GraduationCap },
  { id: 'notas', label: 'Notas', icon: ClipboardCheck },
  { id: 'emails', label: 'Emails', icon: Mail },
];

const emptyAluno = { nome: '', matricula: '', email: '', curso: '', data_ingresso: '' };
const emptyDisciplina = { nome: '', codigo: '', carga_horaria: '', professor: '', semestre: '' };
const emptyNota = { aluno_id: '', disciplina_id: '', valor: '', periodo: '', status: 'em_andamento' };
const emptyEmail = { destinatario: '', assunto: '', mensagem: '' };

const statusColors = {
  aprovado: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/30',
  reprovado: 'bg-red-500/10 text-red-400 border-red-500/30',
  em_andamento: 'bg-amber-500/10 text-amber-400 border-amber-500/30',
};

function AlunoForm({ data, onChange, onSubmit, onCancel, loading }) {
  return (
    <form onSubmit={onSubmit} className="space-y-4">
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Nome *</label>
          <Input value={data.nome} onChange={(e) => onChange({ ...data, nome: e.target.value })} placeholder="Nome completo" required />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Matrícula *</label>
          <Input value={data.matricula} onChange={(e) => onChange({ ...data, matricula: e.target.value })} placeholder="Número de matrícula" required />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Email</label>
          <Input value={data.email} onChange={(e) => onChange({ ...data, email: e.target.value })} placeholder="email@faculdade.edu.br" type="email" />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Curso</label>
          <Input value={data.curso} onChange={(e) => onChange({ ...data, curso: e.target.value })} placeholder="Nome do curso" />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Data de Ingresso</label>
          <Input value={data.data_ingresso} onChange={(e) => onChange({ ...data, data_ingresso: e.target.value })} type="date" />
        </div>
      </div>
      <div className="flex justify-end gap-3 pt-2">
        <Button type="button" variant="outline" onClick={onCancel}>Cancelar</Button>
        <Button type="submit" disabled={loading}>
          {loading && <Loader2 className="w-4 h-4 mr-2 animate-spin" />}
          Salvar
        </Button>
      </div>
    </form>
  );
}

function DisciplinaForm({ data, onChange, onSubmit, onCancel, loading }) {
  return (
    <form onSubmit={onSubmit} className="space-y-4">
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Nome *</label>
          <Input value={data.nome} onChange={(e) => onChange({ ...data, nome: e.target.value })} placeholder="Nome da disciplina" required />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Código *</label>
          <Input value={data.codigo} onChange={(e) => onChange({ ...data, codigo: e.target.value })} placeholder="Ex: CC2024" required />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Carga Horária</label>
          <Input value={data.carga_horaria} onChange={(e) => onChange({ ...data, carga_horaria: e.target.value })} placeholder="Horas" type="number" />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Professor</label>
          <Input value={data.professor} onChange={(e) => onChange({ ...data, professor: e.target.value })} placeholder="Nome do professor" />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Semestre</label>
          <Input value={data.semestre} onChange={(e) => onChange({ ...data, semestre: e.target.value })} placeholder="Ex: 2026.1" />
        </div>
      </div>
      <div className="flex justify-end gap-3 pt-2">
        <Button type="button" variant="outline" onClick={onCancel}>Cancelar</Button>
        <Button type="submit" disabled={loading}>
          {loading && <Loader2 className="w-4 h-4 mr-2 animate-spin" />}
          Salvar
        </Button>
      </div>
    </form>
  );
}

function EmailForm({ data, onChange, onSubmit, onCancel, loading, alunos }) {
  return (
    <form onSubmit={onSubmit} className="space-y-4">
      <div className="grid grid-cols-1 gap-4">
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Destinatário *</label>
          <Input value={data.destinatario} onChange={(e) => onChange({ ...data, destinatario: e.target.value })} placeholder="email@faculdade.edu.br" type="email" required />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Assunto *</label>
          <Input value={data.assunto} onChange={(e) => onChange({ ...data, assunto: e.target.value })} placeholder="Assunto do email" required />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Mensagem</label>
          <Input value={data.mensagem} onChange={(e) => onChange({ ...data, mensagem: e.target.value })} placeholder="Corpo do email" />
        </div>
      </div>
      <div className="flex justify-end gap-3 pt-2">
        <Button type="button" variant="outline" onClick={onCancel}>Cancelar</Button>
        <Button type="submit" disabled={loading}>
          {loading && <Loader2 className="w-4 h-4 mr-2 animate-spin" />}
          Enviar
        </Button>
      </div>
    </form>
  );
}

function NotaForm({ data, onChange, onSubmit, onCancel, loading, alunos, disciplinas }) {
  return (
    <form onSubmit={onSubmit} className="space-y-4">
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Aluno *</label>
          <Select value={data.aluno_id} onValueChange={(v) => onChange({ ...data, aluno_id: v })}>
            <SelectTrigger><SelectValue placeholder="Selecionar aluno" /></SelectTrigger>
            <SelectContent>
              {alunos?.map((a) => (
                <SelectItem key={a.id} value={a.id}>{a.nome} ({a.matricula})</SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Disciplina *</label>
          <Select value={data.disciplina_id} onValueChange={(v) => onChange({ ...data, disciplina_id: v })}>
            <SelectTrigger><SelectValue placeholder="Selecionar disciplina" /></SelectTrigger>
            <SelectContent>
              {disciplinas?.map((d) => (
                <SelectItem key={d.id} value={d.id}>{d.codigo} - {d.nome}</SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Nota (0-10) *</label>
          <Input value={data.valor} onChange={(e) => onChange({ ...data, valor: e.target.value })} placeholder="0 a 10" type="number" min="0" max="10" step="0.1" required />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Período</label>
          <Input value={data.periodo} onChange={(e) => onChange({ ...data, periodo: e.target.value })} placeholder="Ex: 2026.1" />
        </div>
        <div>
          <label className="text-xs text-muted-foreground mb-1 block">Status</label>
          <Select value={data.status} onValueChange={(v) => onChange({ ...data, status: v })}>
            <SelectTrigger><SelectValue /></SelectTrigger>
            <SelectContent>
              <SelectItem value="em_andamento">Em andamento</SelectItem>
              <SelectItem value="aprovado">Aprovado</SelectItem>
              <SelectItem value="reprovado">Reprovado</SelectItem>
            </SelectContent>
          </Select>
        </div>
      </div>
      <div className="flex justify-end gap-3 pt-2">
        <Button type="button" variant="outline" onClick={onCancel}>Cancelar</Button>
        <Button type="submit" disabled={loading}>
          {loading && <Loader2 className="w-4 h-4 mr-2 animate-spin" />}
          Salvar
        </Button>
      </div>
    </form>
  );
}

export default function AdminDashboard() {
  const [activeTab, setActiveTab] = useState('alunos');
  const [dialogOpen, setDialogOpen] = useState(false);
  const [editItem, setEditItem] = useState(null);
  const [formData, setFormData] = useState(null);

  const queryClient = useQueryClient();

  const { data: alunos = [], isLoading: loadingAlunos } = useQuery({
    queryKey: ['admin-alunos'],
    queryFn: () => base44.entities.Aluno.list('-created_date', 100),
  });

  const { data: disciplinas = [], isLoading: loadingDisciplinas } = useQuery({
    queryKey: ['admin-disciplinas'],
    queryFn: () => base44.entities.Disciplina.list('-created_date', 100),
  });

  const { data: notas = [], isLoading: loadingNotas } = useQuery({
    queryKey: ['admin-notas'],
    queryFn: () => base44.entities.Nota.list('-created_date', 100),
  });

  const { data: emails = [], isLoading: loadingEmails } = useQuery({
    queryKey: ['admin-emails'],
    queryFn: () => base44.entities.EmailLog.list('-created_date', 100),
  });

  const createAlunoMutation = useMutation({
    mutationFn: (data) => base44.entities.Aluno.create(data),
    onSuccess: () => { queryClient.invalidateQueries({ queryKey: ['admin-alunos'] }); setDialogOpen(false); setEditItem(null); },
  });

  const updateAlunoMutation = useMutation({
    mutationFn: ({ id, data }) => base44.entities.Aluno.update(id, data),
    onSuccess: () => { queryClient.invalidateQueries({ queryKey: ['admin-alunos'] }); setDialogOpen(false); setEditItem(null); },
  });

  const deleteAlunoMutation = useMutation({
    mutationFn: (id) => base44.entities.Aluno.delete(id),
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['admin-alunos'] }),
  });

  const createDisciplinaMutation = useMutation({
    mutationFn: (data) => base44.entities.Disciplina.create(data),
    onSuccess: () => { queryClient.invalidateQueries({ queryKey: ['admin-disciplinas'] }); setDialogOpen(false); setEditItem(null); },
  });

  const updateDisciplinaMutation = useMutation({
    mutationFn: ({ id, data }) => base44.entities.Disciplina.update(id, data),
    onSuccess: () => { queryClient.invalidateQueries({ queryKey: ['admin-disciplinas'] }); setDialogOpen(false); setEditItem(null); },
  });

  const deleteDisciplinaMutation = useMutation({
    mutationFn: (id) => base44.entities.Disciplina.delete(id),
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['admin-disciplinas'] }),
  });

  const createNotaMutation = useMutation({
    mutationFn: (data) => base44.entities.Nota.create(data),
    onSuccess: () => { queryClient.invalidateQueries({ queryKey: ['admin-notas'] }); setDialogOpen(false); setEditItem(null); },
  });

  const updateNotaMutation = useMutation({
    mutationFn: ({ id, data }) => base44.entities.Nota.update(id, data),
    onSuccess: () => { queryClient.invalidateQueries({ queryKey: ['admin-notas'] }); setDialogOpen(false); setEditItem(null); },
  });

  const deleteNotaMutation = useMutation({
    mutationFn: (id) => base44.entities.Nota.delete(id),
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['admin-notas'] }),
  });

  const createEmailMutation = useMutation({
    mutationFn: async (data) => {
      let status = 'enviado';
      try {
        await base44.integrations.Core.SendEmail({
          to: data.destinatario,
          subject: data.assunto,
          body: data.mensagem || '',
        });
      } catch (e) {
        status = 'erro';
      }
      return base44.entities.EmailLog.create({
        destinatario: data.destinatario,
        assunto: data.assunto,
        status,
      });
    },
    onSuccess: () => { queryClient.invalidateQueries({ queryKey: ['admin-emails'] }); setDialogOpen(false); setEditItem(null); },
  });

  const deleteEmailMutation = useMutation({
    mutationFn: (id) => base44.entities.EmailLog.delete(id),
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['admin-emails'] }),
  });

  const openCreate = () => {
    setEditItem(null);
    if (activeTab === 'alunos') setFormData({ ...emptyAluno });
    else if (activeTab === 'disciplinas') setFormData({ ...emptyDisciplina });
    else if (activeTab === 'notas') setFormData({ ...emptyNota });
    else setFormData({ ...emptyEmail });
    setDialogOpen(true);
  };

  const openEdit = (item) => {
    setEditItem(item);
    const { id, created_date, updated_date, created_by_id, ...rest } = item;
    setFormData({ ...rest, carga_horaria: rest.carga_horaria != null ? String(rest.carga_horaria) : '', valor: rest.valor != null ? String(rest.valor) : '' });
    setDialogOpen(true);
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    const payload = { ...formData };
    if (payload.carga_horaria !== undefined && payload.carga_horaria !== '') payload.carga_horaria = parseInt(payload.carga_horaria, 10);
    if (payload.valor !== undefined && payload.valor !== '') payload.valor = parseFloat(payload.valor);

    if (activeTab === 'emails') {
      createEmailMutation.mutate(payload);
    } else if (editItem) {
      if (activeTab === 'alunos') updateAlunoMutation.mutate({ id: editItem.id, data: payload });
      else if (activeTab === 'disciplinas') updateDisciplinaMutation.mutate({ id: editItem.id, data: payload });
      else updateNotaMutation.mutate({ id: editItem.id, data: payload });
    } else {
      if (activeTab === 'alunos') createAlunoMutation.mutate(payload);
      else if (activeTab === 'disciplinas') createDisciplinaMutation.mutate(payload);
      else createNotaMutation.mutate(payload);
    }
  };

  const handleDelete = (id) => {
    if (activeTab === 'alunos') deleteAlunoMutation.mutate(id);
    else if (activeTab === 'disciplinas') deleteDisciplinaMutation.mutate(id);
    else if (activeTab === 'notas') deleteNotaMutation.mutate(id);
    else deleteEmailMutation.mutate(id);
  };

  const getAlunoNome = (id) => alunos.find(a => a.id === id)?.nome || id?.slice(0, 8);
  const getDisciplinaNome = (id) => disciplinas.find(d => d.id === id)?.nome || id?.slice(0, 8);

  const isMutationLoading =
    createAlunoMutation.isPending || updateAlunoMutation.isPending ||
    createDisciplinaMutation.isPending || updateDisciplinaMutation.isPending ||
    createNotaMutation.isPending || updateNotaMutation.isPending ||
    createEmailMutation.isPending;

  const activeTabObj = tabs.find(t => t.id === activeTab);
  const TabIcon = activeTabObj?.icon;

  return (
    <div className="min-h-screen bg-background">
      <header className="border-b border-border bg-card/50 backdrop-blur sticky top-0 z-20">
        <div className="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center gap-4">
            <Link to="/" className="text-sm text-muted-foreground hover:text-foreground transition-colors">
              ← Documentação
            </Link>
            <h1 className="text-lg font-semibold text-foreground">Painel Administrativo</h1>
          </div>
          <Dialog open={dialogOpen} onOpenChange={(open) => { setDialogOpen(open); if (!open) setEditItem(null); }}>
            <DialogTrigger asChild>
              <Button size="sm" className="gap-1.5" onClick={openCreate}>
                <Plus className="w-4 h-4" />
                Novo
              </Button>
            </DialogTrigger>
            <DialogContent className="sm:max-w-lg">
              <DialogHeader>
                <DialogTitle>
                  {editItem ? `Editar ${activeTabObj?.label?.slice(0, -1)}` : `Novo ${activeTabObj?.label?.slice(0, -1) || 'Registro'}`}
                </DialogTitle>
              </DialogHeader>
              {activeTab === 'alunos' && (
                <AlunoForm data={formData || emptyAluno} onChange={setFormData} onSubmit={handleSubmit} onCancel={() => { setDialogOpen(false); setEditItem(null); }} loading={isMutationLoading} />
              )}
              {activeTab === 'disciplinas' && (
                <DisciplinaForm data={formData || emptyDisciplina} onChange={setFormData} onSubmit={handleSubmit} onCancel={() => { setDialogOpen(false); setEditItem(null); }} loading={isMutationLoading} />
              )}
              {activeTab === 'notas' && (
                <NotaForm data={formData || emptyNota} onChange={setFormData} onSubmit={handleSubmit} onCancel={() => { setDialogOpen(false); setEditItem(null); }} loading={isMutationLoading} alunos={alunos} disciplinas={disciplinas} />
              )}
              {activeTab === 'emails' && (
                <EmailForm data={formData || emptyEmail} onChange={setFormData} onSubmit={handleSubmit} onCancel={() => { setDialogOpen(false); setEditItem(null); }} loading={isMutationLoading} alunos={alunos} />
              )}
            </DialogContent>
          </Dialog>
        </div>
      </header>

      <div className="max-w-6xl mx-auto px-6 py-8">
        {/* Tabs */}
        <div className="flex gap-1 bg-secondary/30 rounded-lg p-1 mb-8 w-fit">
          {tabs.map((tab) => (
            <button
              key={tab.id}
              onClick={() => setActiveTab(tab.id)}
              className={`flex items-center gap-2 px-4 py-2 rounded-md text-sm font-medium transition-all ${
                activeTab === tab.id
                  ? 'bg-background text-foreground shadow-sm'
                  : 'text-muted-foreground hover:text-foreground'
              }`}
            >
              <tab.icon className="w-4 h-4" />
              {tab.label}
            </button>
          ))}
        </div>

        {/* Content */}
        {activeTab === 'alunos' && (
          <div>
            {loadingAlunos ? (
              <div className="flex justify-center py-12"><Loader2 className="w-6 h-6 animate-spin text-muted-foreground" /></div>
            ) : alunos.length === 0 ? (
              <div className="text-center py-16 text-muted-foreground">
                <Users className="w-12 h-12 mx-auto mb-3 opacity-30" />
                <p>Nenhum aluno cadastrado</p>
                <Button variant="outline" size="sm" className="mt-3" onClick={openCreate}>Cadastrar primeiro aluno</Button>
              </div>
            ) : (
              <div className="grid gap-3">
                {alunos.map((aluno) => (
                  <Card key={aluno.id} className="bg-card/60 hover:bg-card transition-colors">
                    <CardContent className="p-4 flex items-center justify-between">
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center gap-3 mb-1">
                          <span className="font-medium text-foreground truncate">{aluno.nome}</span>
                          <Badge variant="outline" className="text-xs font-mono">{aluno.matricula}</Badge>
                        </div>
                        <div className="flex gap-4 text-xs text-muted-foreground">
                          {aluno.curso && <span>{aluno.curso}</span>}
                          {aluno.email && <span>{aluno.email}</span>}
                          {aluno.data_ingresso && <span>Ingresso: {aluno.data_ingresso}</span>}
                        </div>
                      </div>
                      <div className="flex items-center gap-1 ml-4">
                        <Button variant="ghost" size="icon" onClick={() => openEdit(aluno)}>
                          <Pencil className="w-4 h-4" />
                        </Button>
                        <Button variant="ghost" size="icon" onClick={() => handleDelete(aluno.id)}>
                          <Trash2 className="w-4 h-4 text-muted-foreground hover:text-red-400 transition-colors" />
                        </Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}
          </div>
        )}

        {activeTab === 'disciplinas' && (
          <div>
            {loadingDisciplinas ? (
              <div className="flex justify-center py-12"><Loader2 className="w-6 h-6 animate-spin text-muted-foreground" /></div>
            ) : disciplinas.length === 0 ? (
              <div className="text-center py-16 text-muted-foreground">
                <GraduationCap className="w-12 h-12 mx-auto mb-3 opacity-30" />
                <p>Nenhuma disciplina cadastrada</p>
                <Button variant="outline" size="sm" className="mt-3" onClick={openCreate}>Cadastrar primeira disciplina</Button>
              </div>
            ) : (
              <div className="grid gap-3">
                {disciplinas.map((disc) => (
                  <Card key={disc.id} className="bg-card/60 hover:bg-card transition-colors">
                    <CardContent className="p-4 flex items-center justify-between">
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center gap-3 mb-1">
                          <span className="font-medium text-foreground truncate">{disc.nome}</span>
                          <Badge variant="outline" className="text-xs font-mono">{disc.codigo}</Badge>
                          {disc.semestre && <Badge variant="secondary" className="text-xs">{disc.semestre}</Badge>}
                        </div>
                        <div className="flex gap-4 text-xs text-muted-foreground">
                          {disc.professor && <span>Prof. {disc.professor}</span>}
                          {disc.carga_horaria && <span>{disc.carga_horaria}h</span>}
                        </div>
                      </div>
                      <div className="flex items-center gap-1 ml-4">
                        <Button variant="ghost" size="icon" onClick={() => openEdit(disc)}>
                          <Pencil className="w-4 h-4" />
                        </Button>
                        <Button variant="ghost" size="icon" onClick={() => handleDelete(disc.id)}>
                          <Trash2 className="w-4 h-4 text-muted-foreground hover:text-red-400 transition-colors" />
                        </Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}
          </div>
        )}

        {activeTab === 'notas' && (
          <div>
            {loadingNotas ? (
              <div className="flex justify-center py-12"><Loader2 className="w-6 h-6 animate-spin text-muted-foreground" /></div>
            ) : notas.length === 0 ? (
              <div className="text-center py-16 text-muted-foreground">
                <ClipboardCheck className="w-12 h-12 mx-auto mb-3 opacity-30" />
                <p>Nenhuma nota lançada</p>
                <Button variant="outline" size="sm" className="mt-3" onClick={openCreate}>Lançar primeira nota</Button>
              </div>
            ) : (
              <div className="grid gap-3">
                {notas.map((nota) => (
                  <Card key={nota.id} className="bg-card/60 hover:bg-card transition-colors">
                    <CardContent className="p-4 flex items-center justify-between">
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center gap-3 mb-1 flex-wrap">
                          <span className="font-medium text-foreground">{getAlunoNome(nota.aluno_id)}</span>
                          <span className="text-muted-foreground text-sm">→ {getDisciplinaNome(nota.disciplina_id)}</span>
                          <span className="font-mono font-semibold text-foreground">{nota.valor}</span>
                          <Badge className={`text-xs border ${statusColors[nota.status] || ''}`}>
                            {nota.status === 'aprovado' ? 'Aprovado' : nota.status === 'reprovado' ? 'Reprovado' : 'Em andamento'}
                          </Badge>
                        </div>
                        <div className="text-xs text-muted-foreground">
                          {nota.periodo && <span>Período: {nota.periodo}</span>}
                        </div>
                      </div>
                      <div className="flex items-center gap-1 ml-4">
                        <Button variant="ghost" size="icon" onClick={() => openEdit(nota)}>
                          <Pencil className="w-4 h-4" />
                        </Button>
                        <Button variant="ghost" size="icon" onClick={() => handleDelete(nota.id)}>
                          <Trash2 className="w-4 h-4 text-muted-foreground hover:text-red-400 transition-colors" />
                        </Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}
          </div>
        )}

        {activeTab === 'emails' && (
          <div>
            {loadingEmails ? (
              <div className="flex justify-center py-12"><Loader2 className="w-6 h-6 animate-spin text-muted-foreground" /></div>
            ) : emails.length === 0 ? (
              <div className="text-center py-16 text-muted-foreground">
                <Mail className="w-12 h-12 mx-auto mb-3 opacity-30" />
                <p>Nenhum email enviado</p>
                <Button variant="outline" size="sm" className="mt-3" onClick={openCreate}>Enviar primeiro email</Button>
              </div>
            ) : (
              <div className="grid gap-3">
                {emails.map((email) => (
                  <Card key={email.id} className="bg-card/60 hover:bg-card transition-colors">
                    <CardContent className="p-4 flex items-center justify-between">
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center gap-3 mb-1 flex-wrap">
                          <span className="font-medium text-foreground">{email.destinatario}</span>
                          <span className="text-muted-foreground text-sm truncate max-w-xs">{email.assunto}</span>
                          <Badge className={`text-xs border ${email.status === 'erro' ? 'bg-red-500/10 text-red-400 border-red-500/30' : 'bg-emerald-500/10 text-emerald-400 border-emerald-500/30'}`}>
                            {email.status === 'erro' ? 'Erro' : 'Enviado'}
                          </Badge>
                        </div>
                        <div className="text-xs text-muted-foreground">
                          {email.created_date && <span>{new Date(email.created_date).toLocaleString('pt-BR')}</span>}
                        </div>
                      </div>
                      <div className="flex items-center gap-1 ml-4">
                        <Button variant="ghost" size="icon" onClick={() => handleDelete(email.id)}>
                          <Trash2 className="w-4 h-4 text-muted-foreground hover:text-red-400 transition-colors" />
                        </Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
